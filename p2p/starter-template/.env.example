# anet daemon
ANET_BASE_URL=http://127.0.0.1:3998
# ANET_TOKEN=<paste output of: anet auth token print>

# backend
MY_BACKEND_HOST=127.0.0.1
MY_BACKEND_PORT=8000

# service identity
MY_SVC_NAME=my-agent
MY_SVC_DESC=p2p starter agent

# exposed paths (comma-separated)
MY_SVC_PATHS=/echo,/health,/meta,/stream

# routing modes (rr = request/response; add server-stream for streaming)
MY_SVC_MODES=rr

# skill tags — used by `anet svc discover --skill=...`
MY_SVC_TAGS=p2p

# cost model: set MY_SVC_FREE=false and uncomment to charge credits
MY_SVC_FREE=true
# MY_SVC_PER_CALL=10
# MY_SVC_PER_KB=1
# MY_SVC_DEPOSIT=100

# discovery target for client.py
TARGET_SKILL=p2p
